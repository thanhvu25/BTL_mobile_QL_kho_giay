<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:id="@+id/layout_sanPham">

    <!-- Background -->

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:scaleType="centerCrop"
        android:src="@drawable/img_bg" />

    <!-- Header -->
    <LinearLayout
        android:id="@+id/headerLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_margin="5dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="3"
            android:background="@drawable/bg_transparent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:padding="8dp">

            <ImageView
                android:layout_width="60dp"
                android:layout_height="match_parent"
                android:scaleType="fitCenter"
                android:src="@drawable/logo" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:text="Quản lý sản phẩm"
                android:textColor="#022c36"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <Button
            android:id="@+id/btnDangXuat"
            android:layout_width="0dp"
            android:layout_height="60dp"
            android:layout_weight="1"
            android:layout_marginStart="8dp"
            android:background="@drawable/menu_button"
            android:text="Đăng xuất"
            android:textAllCaps="false"
            android:textColor="#000000" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@id/headerLayout"
        android:layout_above="@id/bottomNav">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="5dp">

        <!-- Tìm kiếm -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <EditText
                    android:id="@+id/edtSearch"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="Tìm kiếm..."
                    android:background="@drawable/edt"
                    android:padding="10dp"
                    android:textColor="#022c36"/>

                <Button
                    android:id="@+id/btnSearch"
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_marginStart="7dp"
                    android:background="@drawable/button"
                    android:text="Tìm" />

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="5dp">

                <!-- Mã sản phẩm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp"
                    android:layout_marginTop="5dp">

                    <TextView
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Mã sản phẩm"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#022c36"/>

                    <EditText
                        android:id="@+id/edtMaSP"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/edt"
                        android:hint="Mã sản phẩm"
                        android:padding="15dp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="18sp"
                        android:inputType="number"/>
                </LinearLayout>


                <!-- Tên sản phẩm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Tên sản phẩm"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#022c36"/>

                    <EditText
                        android:id="@+id/edtTenSP"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/edt"
                        android:hint="Tên sản phẩm"
                        android:padding="15dp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="18sp" />
                </LinearLayout>


                <!-- Loại sản phẩm -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Loại sản phẩm"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#022c36"/>

                    <Spinner
                        android:id="@+id/spLoai"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/edt"
                        android:padding="15dp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="18sp"/>
                </LinearLayout>


                <!-- Nhà cung cấp -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Nhà cung cấp"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#022c36"/>

                    <Spinner
                        android:id="@+id/spNCC"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/edt"
                        android:padding="15dp"
                        android:autofillHints="Chọn nhà cung cấp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="18sp"/>
                </LinearLayout>


                <!-- Size -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Size"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#022c36"/>

                    <Spinner
                        android:id="@+id/spSize"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/edt"
                        android:padding="15dp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="18sp"/>
                </LinearLayout>


                <!-- Giá nhập -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Giá nhập"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#022c36"/>

                    <EditText
                        android:id="@+id/edtGiaNhap"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/edt"
                        android:hint="Giá nhập"
                        android:padding="15dp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="18sp"/>
                </LinearLayout>


                <!-- Tồn kho -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="10dp">

                    <TextView
                        android:layout_width="130dp"
                        android:layout_height="wrap_content"
                        android:text="Số lượng tồn"
                        android:textStyle="bold"
                        android:textSize="18sp"
                        android:textColor="#022c36"/>

                    <EditText
                        android:id="@+id/edtSoLuongTon"
                        android:layout_width="match_parent"
                        android:layout_height="55dp"
                        android:background="@drawable/edt"
                        android:hint="0"
                        android:enabled="false"
                        android:padding="15dp"
                        android:textColor="#333333"
                        android:textColorHint="#888888"
                        android:textSize="18sp"/>
                </LinearLayout>
            </LinearLayout>


            <!-- Button -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center">

                <!-- Hình ảnh -->
                <Button
                    android:id="@+id/btnChonAnh"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="Chọn ảnh"
                    android:background="@drawable/button"/>

                <!-- Thêm -->
                <Button
                    android:id="@+id/btnThem_SP"
                    android:layout_width="160dp"
                    android:layout_height="wrap_content"
                    android:layout_margin="12dp"
                    android:text="Thêm sản phẩm"
                    android:background="@drawable/button"/>
            </LinearLayout>


            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Danh sách sản phẩm"
                android:textColor="#022c36"
                android:textSize="30sp"
                android:textStyle="bold"
                android:gravity="center"/>

            <ListView
                android:id="@+id/lvSanPham"
                android:layout_width="match_parent"
                android:layout_height="550dp"
                android:layout_marginTop="10dp"
                android:background="#FFFFFF"
                android:textColor="#022c36"/>


        </LinearLayout>
    </ScrollView>

    <!-- Bottom Navigation -->
    <LinearLayout
        android:id="@+id/bottomNav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:background="#fff4e2"
        android:layout_alignParentBottom="true"
        android:orientation="horizontal">

        <Button
            android:id="@+id/btnTaiKhoan"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/menu_button"
            android:text="Tài khoản" />

        <Button
            android:id="@+id/btnTrangChu"
            android:layout_width="0dp"
            android:layout_height="50dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/menu_button"
            android:text="Trang chủ" />

        <Button
            android:id="@+id/btnCaiDat"
            android:layout_width="0dp"
            android:layout_height="40dp"
            android:layout_weight="1"
            android:layout_margin="4dp"
            android:background="@drawable/menu_button"
            android:text="Cài đặt" />
    </LinearLayout>

</RelativeLayout>