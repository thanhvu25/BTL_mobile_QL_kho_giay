<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_pressed="true">
        <shape>
            <solid android:color="#F6BE4F"/>
            <corners android:radius="18dp"/>
            <stroke
                android:width="2dp"
                android:color="#E6A800"/>
        </shape>
    </item>

    <item>
        <shape>
            <solid android:color="#FFE2AF"/>
            <corners android:radius="18dp"/>
            <stroke
                android:width="2dp"
                android:color="#F0C040"/>
        </shape>
    </item>

</selector>